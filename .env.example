# Alpaca paper trading (https://alpaca.markets)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Polygon.io market data (https://polygon.io)
POLYGON_API_KEY=your_polygon_api_key

# Execution policy (optional — defaults are safe/paper)
# LLM_TRADING_ENABLED=false
# LLM_TRADING_MODE=paper
# LLM_MAX_NOTIONAL_USD=500
# LLM_MAX_TRADES_PER_DAY=5
# LLM_MIN_SECONDS_BETWEEN_TRADES=60
# LLM_REQUIRE_LIVE_TOKEN=true
# LLM_LIVE_TOKEN=your_secret_confirmation_token
# LLM_ALLOWED_SYMBOLS=AAPL,MSFT,BTC/USD
# LLM_ALLOWED_ASSET_CLASSES=us_equity,crypto
